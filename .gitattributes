# Unreal Engine 5 - Git LFS + Exclusive Locking

# Binary assets (lock to prevent merge conflicts)
*.uasset filter=lfs diff=lfs merge=lfs -text lock
*.umap   filter=lfs diff=lfs merge=lfs -text lock
*.ubulk  filter=lfs diff=lfs merge=lfs -text lock
*.utexture filter=lfs diff=lfs merge=lfs -text lock
*.upk    filter=lfs diff=lfs merge=lfs -text lock
*.bin    filter=lfs diff=lfs merge=lfs -text lock
*.wav    filter=lfs diff=lfs merge=lfs -text lock
*.mp3    filter=lfs diff=lfs merge=lfs -text lock
*.ogg    filter=lfs diff=lfs merge=lfs -text lock
*.mp4    filter=lfs diff=lfs merge=lfs -text lock

# Large text-based assets (optional locking)
*.ini    filter=lfs diff=lfs merge=lfs -text
*.json   filter=lfs diff=lfs merge=lfs -text
*.xml    filter=lfs diff=lfs merge=lfs -text

# Ignore line ending changes for binary files
*.uasset -text
*.umap   -text